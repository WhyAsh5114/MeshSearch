# MeshSearch Environment Configuration

# Search Backend
SEARCH_BACKEND_URL=http://localhost:4001
BACKEND_PRIVATE_KEY=<32-byte-hex-secp256k1-private-key>
SEARXNG_URL=http://localhost:8888
BRAVE_API_KEY=

# Relay Nodes (format: url|publicKey|ensName for each)
RELAY_ENDPOINTS=http://localhost:4002|<relay1-compressed-pubkey-hex>|relay1.meshsearch.eth,http://localhost:4003|<relay2-compressed-pubkey-hex>|relay2.meshsearch.eth,http://localhost:4004|<relay3-compressed-pubkey-hex>|relay3.meshsearch.eth

# Fileverse
FILEVERSE_API_URL=http://localhost:4005

# Blockchain (local Hardhat or Base Sepolia)
RPC_URL=http://localhost:8545
DEPLOYER_PRIVATE_KEY=
BACKEND_PUBLIC_KEY=<33-byte-compressed-secp256k1-public-key-hex>

# Semaphore identity secret (for ZK proof generation)
SEMAPHORE_SECRET=<random-32-byte-hex>

# Contract Addresses (set after deployment)
NODE_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
NULLIFIER_REGISTRY_ADDRESS=0x0000000000000000000000000000000000000000
PAYMENT_SPLITTER_ADDRESS=0x0000000000000000000000000000000000000000
ACCESS_CONTROL_ADDRESS=0x0000000000000000000000000000000000000000
