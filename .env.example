# MeshSearch Environment Configuration

# Search Backend
SEARCH_BACKEND_URL=http://localhost:4001
BACKEND_PRIVATE_KEY=<32-byte-hex-secp256k1-private-key>
SEARXNG_URL=http://localhost:8888
BRAVE_API_KEY=

# Relay Nodes (format: url|publicKey|ensName for each)
RELAY_ENDPOINTS=http://localhost:4002|<relay1-compressed-pubkey-hex>|relay1.meshsearch.eth,http://localhost:4003|<relay2-compressed-pubkey-hex>|relay2.meshsearch.eth,http://localhost:4004|<relay3-compressed-pubkey-hex>|relay3.meshsearch.eth

# Fileverse history transport
FILEVERSE_TRANSPORT=mcp
FILEVERSE_SERVER_URL=

# Fileverse local API (legacy wrapper)
FILEVERSE_API_URL=http://localhost:4005

# Fileverse remote storage
FILEVERSE_STORAGE_URL=
FILEVERSE_AUTH_MODE=apiKey
FILEVERSE_API_KEY=
FILEVERSE_API_KEY_HEADER=X-API-Key
FILEVERSE_API_KEY_PREFIX=
FILEVERSE_UPLOAD_PATH=
FILEVERSE_GATEWAY=https://ipfs.io/ipfs
FILEVERSE_ENCRYPTION_KEY=
FILEVERSE_SYNC_TIMEOUT_MS=60000
FILEVERSE_SYNC_POLL_INTERVAL_MS=3000

# Blockchain (local Hardhat or Base Sepolia)
RPC_URL=https://base-sepolia.g.alchemy.com/v2/TsD5q7yvfBmn6byKNh4xm
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/TsD5q7yvfBmn6byKNh4xm
DEPLOYER_PRIVATE_KEY=0x6d537b0335de650105890de72c23d42aa0641d5cf94604787d1ac98ace2c3351
BACKEND_PUBLIC_KEY=<33-byte-compressed-secp256k1-public-key-hex>

# Semaphore identity secret (for ZK proof generation)
SEMAPHORE_SECRET=<random-32-byte-hex>

# Contract Addresses (Base Sepolia deployment)
NODE_REGISTRY_ADDRESS=0xB9441DE5339304B1A071cd3aa30F5A1792a14f62
NULLIFIER_REGISTRY_ADDRESS=0xf7929A2f91785A01cE04C044aa34839D5657989e
PAYMENT_SPLITTER_ADDRESS=0xAFB6F1C87A45Bbf3ef42624EE3db66bD558dC17B
ACCESS_CONTROL_ADDRESS=0xc5c52C190BC3B8bdf7DC21F363EA5023beb31143
